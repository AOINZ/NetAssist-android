<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_command_item"
    android:layout_marginBottom="8dp"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_command_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btn_send_command"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_send_small"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="发送"
            android:scaleType="centerInside"
            android:tint="@color/white"
            android:elevation="2dp"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btn_delete_command"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_delete"
            android:src="@android:drawable/ic_menu_delete"
            android:contentDescription="删除"
            android:scaleType="centerInside"
            android:tint="@color/white"
            android:elevation="2dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_command_data"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="4dp"
        android:fontFamily="monospace" />
</LinearLayout>
